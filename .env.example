# ── Server ────────────────────────────────────────────────
MASTER_HOST=0.0.0.0
MASTER_PORT=9000
MASTER_DEBUG=false

# ── Single database (all modules use lit_db) ───────────────
DATABASE_URL=postgresql+psycopg2://postgres:123456@localhost:5432/lit_db

# ── Kirana AI ──────────────────────────────────────────────
KIRANA_API_KEY=kirana-dev-key
# ML paths default to ./ml_models/ inside the backend dir
# ML_RESULTS_DIR=./ml_models/results
# ML_ARTIFACTS_DIR=./ml_models/artifacts

# ── POS JWT Auth ───────────────────────────────────────────
POS_SECRET_KEY=change-this-in-production
POS_ALGORITHM=HS256
POS_TOKEN_EXPIRE_MINUTES=43200

# ── WhatsApp Business API ──────────────────────────────────
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v25.0
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=kirana_verify_token

# ── Gemini AI (server-side proxy — never put this in the mobile app) ──────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Mistral AI (for WhatsApp intelligence + explanations) ──
MISTRAL_API_KEY=your_mistral_key_here
MISTRAL_MODEL=mistral-small-latest

AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here
CONSENT_AUDIO_CONTAINER=udhaar-consent